# Internal Sea — environment template
# Copy to .env at the repository root: cp .env.example .env
#
# Local development:
#   - Use localhost for POSTGRES_HOST / DATABASE_URL when running `make api-dev` on the host.
#   - Use postgres/redis hostnames when running via `make docker-up` (see DATABASE_URL below).
#
# Production:
#   - Change JWT_SECRET_KEY and database passwords.
#   - Set APP_ENV=production, DEBUG=false, AUTH_ENABLED=true.
#   - Restrict CORS_ORIGINS to your real frontend origin (no wildcard).
#   - Demo users and seed data are for local/demo only — do not seed production.

APP_NAME=Internal Sea API
APP_ENV=local
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=internal_sea_core
POSTGRES_USER=internal_sea
POSTGRES_PASSWORD=internal_sea

# Docker Compose: hostname "postgres"
# DATABASE_URL=postgresql+asyncpg://internal_sea:internal_sea@postgres:5432/internal_sea_core
# Local api-dev on host:
DATABASE_URL=postgresql+asyncpg://internal_sea:internal_sea@localhost:5432/internal_sea_core

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MUST change before any production-like deployment
JWT_SECRET_KEY=change_me_later
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_ENABLED=true

PASSWORD_MIN_LENGTH=8
RATE_LIMIT_ENABLED=false

CORS_ORIGINS=http://localhost:5173

# Background worker (optional separate process)
WORKER_ENABLED=false
WORKER_POLL_INTERVAL_SECONDS=30
WORKER_BATCH_SIZE=10
WORKER_INSTANCE_ID=local-worker
WORKER_LOCK_TIMEOUT_SECONDS=300

# Automation worker execution
AUTOMATION_REAL_RUN_ENABLED=true
AUTOMATION_DEFAULT_SIMULATE=false

# Notification worker delivery (external delivery disabled in MVP)
NOTIFICATION_EXTERNAL_DELIVERY_ENABLED=false
NOTIFICATION_WORKER_SIMULATE_EXTERNAL=true

# Frontend (Vite build-time variable; also used by docker-compose web service)
VITE_API_BASE_URL=http://localhost:8000/api/v1
